# =============================================================================
# Phase 24 — Dimensional Layer Key-Vault Structure
# =============================================================================
# Copy this file to .env and populate with real credentials.
# NEVER commit the populated .env file (it is in .gitignore).
#
# Isolation rule: Layer 1 data must never bleed into Layer 2/3 workspaces.
# Each layer runs with its own credential set and HF/GitHub namespace.
# =============================================================================

# ── Layer 1 — Primary sovereign layer (main Citadel accounts) ─────────────
GH_TOKEN_LAYER_1=
GH_ORG_LAYER_1=DJ-Goana-Coding
HF_TOKEN_LAYER_1=
HF_NAMESPACE_LAYER_1=DJ-Goana-Coding
GOOGLE_CREDS_LAYER_1=

# ── Layer 2 — Secondary dimensional layer (shadow / backup accounts) ───────
GH_TOKEN_LAYER_2=
GH_ORG_LAYER_2=
HF_TOKEN_LAYER_2=
HF_NAMESPACE_LAYER_2=
GOOGLE_CREDS_LAYER_2=

# ── Layer 3 — Tertiary dimensional layer (ops / stealth accounts) ──────────
GH_TOKEN_LAYER_3=
GH_ORG_LAYER_3=
HF_TOKEN_LAYER_3=
HF_NAMESPACE_LAYER_3=
GOOGLE_CREDS_LAYER_3=

# ── Shared / legacy credentials ────────────────────────────────────────────
# These are used by existing modules and fall back to Layer 1 values.
DRIVE_SERVICE_KEY=
HUGGINGFACE_TOKEN=
HF_TOKEN=

# ── HWID Lock — Chance Root (Pioneer V23 live-trade gate) ──────────────────
CHANC_HWID=
CHANC_ROOT_PATH=
PSINERGY_SCORE=

# ── Phase 24 — Cloud-to-Metal Sync paths ───────────────────────────────────
RECOVERY_STAGING_PATH=E:\\RECOVERY_STAGING\\
CITADEL_ROOT_PATH=C:\\Citadel\\
